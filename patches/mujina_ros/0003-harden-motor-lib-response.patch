+
+class CanResponseError(RuntimeError):
+    """Base class for validated motor response failures."""
+
+
+class CanMotorTimeoutError(TimeoutError):
+    def __init__(self, message, unexpected_frames=None):
+        super().__init__(message)
+        self.unexpected_frames = unexpected_frames or []
+
+
+class UnexpectedCanIdError(CanResponseError):
+    pass
+
+
+class CanDlcError(CanResponseError):
+    pass
+
+
+class MotorError(CanResponseError):
