             return can_id, can_dlc, data[:can_dlc]
         except Exception as e:
-            print('Unable to Receive CAN Frame.')
-            print('Error: ', e)
+            if isinstance(e, socket.timeout):
+                raise CanMotorTimeoutError('Timed out receiving CAN frame') from e
+            raise CanResponseError('Unable to receive CAN frame') from e
+
+    def _format_can_frame(self, can_id, can_dlc, data):
+        return 'id=0x{:x}, dlc={}, data={}'.format(can_id, can_dlc, data.hex())
+
+    def _response_matches_motor_id(self, can_id, data):
+        if self.motor_type == "RobStride02":
+            return (
+                ((can_id >> 8) & 0xff) == self.motor_id
+                or (can_id & 0xff) == self.motor_id
+            )
+        return can_id == self.motor_id or (len(data) > 0 and data[0] == self.motor_id)
+
+    def _expected_response_dlc(self):
+        if self.motor_type == "RobStride02":
+            return 8
+        return 6
+
+    def _check_motor_error(self, can_id):
+        if self.motor_type != "RobStride02":
+            return
+        communication_type = (can_id & 0x3f000000) >> 24
+        error_code = (can_id & 0x3f0000) >> 16
+        if communication_type == 2 and error_code != 0:
+            raise MotorError(
+                'Motor 0x{:x} reported error_code=0x{:x}'.format(
+                    self.motor_id, error_code
+                )
+            )
+
+    def _validate_motor_response(self, can_id, can_dlc, data, min_dlc):
+        if not self._response_matches_motor_id(can_id, data):
+            raise UnexpectedCanIdError(
+                'Expected response from motor 0x{:x}, got {}'.format(
+                    self.motor_id, self._format_can_frame(can_id, can_dlc, data)
+                )
+            )
+        if can_dlc < min_dlc:
+            raise CanDlcError(
+                'Expected response dlc >= {}, got {}'.format(
+                    min_dlc, self._format_can_frame(can_id, can_dlc, data)
+                )
+            )
+        self._check_motor_error(can_id)
+
+    def _recv_expected_motor_frame(self, min_dlc=None):
+        if min_dlc is None:
+            min_dlc = self._expected_response_dlc()
+        unexpected_frames = []
+        while True:
+            try:
+                can_id, can_dlc, data = self._recv_can_frame()
+            except CanMotorTimeoutError as e:
+                message = 'Timed out waiting for response from motor 0x{:x}'.format(
+                    self.motor_id
+                )
+                if unexpected_frames:
+                    message += '; unexpected frames: {}'.format(
+                        ', '.join(unexpected_frames)
+                    )
+                raise CanMotorTimeoutError(
+                    message, unexpected_frames=unexpected_frames
+                ) from e
+
+            if not self._response_matches_motor_id(can_id, data):
+                unexpected_frames.append(
+                    self._format_can_frame(can_id, can_dlc, data)
+                )
+                continue
+
+            self._validate_motor_response(can_id, can_dlc, data, min_dlc)
+            return can_id, can_dlc, data

